{
  "manifest_version": 3,
  "name": "Browser Gateway",
  "version": "0.1.1",
  "description": "Routes this Chrome profile through a private HTTPS proxy.",
  "key": "",
  "minimum_chrome_version": "116",
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Browser Gateway",
    "default_popup": "popup.html"
  }
}
